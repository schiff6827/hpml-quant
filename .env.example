# HPML Model Manager environment template.
#
# Copy this file to `.env` for local runs:
#   cp .env.example .env
#
# Do not commit `.env`; it may contain machine-specific paths or secrets.

# Model/cache locations. The app creates these directories on startup.
# Use a path with enough free disk space for large Hugging Face checkpoints.
MODEL_CACHE_DIR=/opt/hpml_project/models
LOCAL_MODELS_DIR=/opt/hpml_project/models/local

# NiceGUI app binding.
APP_HOST=0.0.0.0
APP_PORT=8080
APP_HOSTNAME=localhost

# NiceGUI storage secret. Change for any shared or persistent deployment.
STORAGE_SECRET=change-me-for-local-runs

# vLLM defaults used by the GUI and queue.
VLLM_PORT_START=8001
DEFAULT_GPU_MEM_UTIL=0.90
DEFAULT_DTYPE=auto
DEFAULT_SEARCH_LIMIT=500

# Optional: export a Hugging Face token in your shell for gated models.
# The GUI also lets you save a token under Settings.
# HF_TOKEN=hf_...
